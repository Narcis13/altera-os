# Altera OS — environment template. Copy to .env.local for dev.

# Core
NODE_ENV=development
LOG_LEVEL=info

# Server
PORT=4000
HOST=127.0.0.1

# Database
DATABASE_URL=./data/altera.db

# Auth
# Generate with: bunx node --eval "console.log(crypto.randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-please-generate-a-long-random-secret
JWT_ACCESS_TTL=86400         # 24h
JWT_REFRESH_TTL=604800       # 7d

# Encryption (for is_sensitive attributes)
ENCRYPTION_KEY=change-me-32-bytes-base64-encoded

# LLM (phase 2+)
ANTHROPIC_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173
