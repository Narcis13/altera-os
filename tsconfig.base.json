{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@altera/core": ["packages/@altera/core/src/index.ts"],
      "@altera/core/*": ["packages/@altera/core/src/*"],
      "@altera/db": ["packages/@altera/db/src/index.ts"],
      "@altera/db/*": ["packages/@altera/db/src/*"],
      "@altera/auth": ["packages/@altera/auth/src/index.ts"],
      "@altera/auth/*": ["packages/@altera/auth/src/*"],
      "@altera/events": ["packages/@altera/events/src/index.ts"],
      "@altera/events/*": ["packages/@altera/events/src/*"],
      "@altera/ingest": ["packages/@altera/ingest/src/index.ts"],
      "@altera/ingest/*": ["packages/@altera/ingest/src/*"],
      "@altera/eav": ["packages/@altera/eav/src/index.ts"],
      "@altera/eav/*": ["packages/@altera/eav/src/*"],
      "@altera/agent": ["packages/@altera/agent/src/index.ts"],
      "@altera/agent/*": ["packages/@altera/agent/src/*"],
      "@altera/loom": ["packages/@altera/loom/src/index.ts"],
      "@altera/loom/*": ["packages/@altera/loom/src/*"],
      "@altera/docs": ["packages/@altera/docs/src/index.ts"],
      "@altera/docs/*": ["packages/@altera/docs/src/*"],
      "@altera/flows": ["packages/@altera/flows/src/index.ts"],
      "@altera/flows/*": ["packages/@altera/flows/src/*"]
    }
  }
}
